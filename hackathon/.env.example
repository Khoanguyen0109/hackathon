# ---- Backend (FastAPI + AI Forecaster) ----

# Directory containing mock Excel data files (e.g. sample_data.xlsx).
AI_FORECASTER_EXAMPLES_DIR=/app/examples

# Matplotlib backend — use "Agg" for headless/server environments.
MPLBACKEND=Agg

# Hugging Face model cache location (avoids re-downloading on restart).
HF_HOME=/root/.cache/huggingface
TRANSFORMERS_CACHE=/root/.cache/huggingface/transformers

# PORT is injected by Railway (and most PaaS). Defaults to 8000.
# PORT=8000

# ---- Build-time (Docker) ----

# CPU-only PyTorch wheels — remove or change for GPU builds.
# TORCH_INDEX_URL=https://download.pytorch.org/whl/cpu
