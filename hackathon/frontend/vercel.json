{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://bytecoach-api-production.up.railway.app/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://bytecoach-api-production.up.railway.app/health"
    },
    {
      "source": "/((?!api|health|assets|favicon).*)",
      "destination": "/index.html"
    }
  ]
}
